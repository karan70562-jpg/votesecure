# Copy this file to .env.local for local development
# On Vercel: add these in Project Settings → Environment Variables

# Your MongoDB Atlas connection string
# Get it from: Atlas Dashboard → Connect → Drivers → copy the URI
# Replace <password> with your actual DB user password
MONGODB_URI=mongodb+srv://youruser:yourpassword@yourcluster.mongodb.net/votesecure?retryWrites=true&w=majority

# Secret key for signing JWT tokens — make this long and random
# You can generate one at: https://generate-secret.vercel.app/32
JWT_SECRET=replace_this_with_a_long_random_secret_string
